## Configuração de CI/CD

### GitHub Actions (Exemplo)

```yaml
# .github/workflows/quality.yml
name: Quality Checks

on: [push, pull_request]

jobs:
 test:
 runs-on: ubuntu-latest
 steps:
 - uses: actions/checkout@v3
 - name: Run tests
 run: {{ stack_commands.test }} --cov
 - name: Check coverage
 run: |
 coverage=$({{ stack_commands.test }} --cov-report=term | grep TOTAL | awk '{print $NF}')
 if (( $(echo "$coverage < 80" | bc -l) )); then
 echo "Coverage $coverage% is below 80%"
 exit 1
 fi
 
 lint:
 runs-on: ubuntu-latest
 steps:
 - uses: actions/checkout@v3
 - name: Run linting
 run: {{ stack_commands.lint }}
```

