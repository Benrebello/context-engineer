### Validação de Input (Pydantic)

```python
# src/application/dtos/user_dto.py
from pydantic import BaseModel, EmailStr, validator
import re

class UserCreateDTO(BaseModel):
 email: EmailStr
 password: str
 full_name: str
 
 @validator('password')
 def validate_password(cls, v):
 """Validate password strength"""
 if len(v) < 8:
 raise ValueError('Password must be at least 8 characters')
 if not re.search(r'[A-Z]', v):
 raise ValueError('Password must contain uppercase letter')
 if not re.search(r'[a-z]', v):
 raise ValueError('Password must contain lowercase letter')
 if not re.search(r'\d', v):
 raise ValueError('Password must contain digit')
 return v
```

### LGPD: Direito ao Esquecimento

```python
# src/interfaces/api/users.py
@router.delete("/api/v1/users/{user_id}")
@require_permission("users:delete")
async def delete_user(user_id: UUID, current_user: User = Depends(get_current_user)):
 """Delete user data (LGPD: Direito ao Esquecimento)"""
 # Anonimizar dados pessoais
 user = await user_repository.get(user_id)
 user.email = f"deleted_{user.id}@deleted.local"
 user.full_name = "Deleted User"
 user.phone = None
 user.is_active = False
 await user_repository.save(user)
 
 # Log para auditoria (sem PII)
 logger.info("user_deleted", user_id=str(user_id), deleted_by=str(current_user.id))
 
 return {"message": "User data anonymized"}
```

{% elif stack == "node-react" %}
### Autenticação JWT Segura

```typescript
// src/infrastructure/security/jwt.ts
import jwt from 'jsonwebtoken';
import bcrypt from 'bcrypt';

const SECRET_KEY = process.env.SECRET_KEY!;
const ACCESS_TOKEN_EXPIRE = '15m';
const REFRESH_TOKEN_EXPIRE = '7d';

export function createAccessToken(payload: object): string {
 return jwt.sign(payload, SECRET_KEY, { expiresIn: ACCESS_TOKEN_EXPIRE });
}

export async function hashPassword(password: string): Promise<string> {
 return bcrypt.hash(password, 10);
}

export async function verifyPassword(password: string, hash: string): Promise<boolean> {
 return bcrypt.compare(password, hash);
}
```

