<html>
  <head>
    <meta charset="utf-8" />
    <title>Dashboard Global</title>
    <style>
      body { font-family: Arial, sans-serif; margin: 40px; color: #0f172a; }
      table { border-collapse: collapse; width: 100%; margin-top: 16px; }
      th, td { padding: 8px 12px; border-bottom: 1px solid #e2e8f0; text-align: left; }
      th { background: #0f172a; color: #fff; }
    </style>
  </head>
  <body>
    <h1>Dashboard Global de Eficiência</h1>
    <p>{{ filter_text }}</p>
    <section>
      <h2>Métricas Médias</h2>
      <ul>
        <li>Tempo médio PRP: {{ avg_metrics.avg_prp_generation_time | default(0) | round(1) }} min</li>
        <li>Taxa média conclusão: {{ avg_metrics.avg_task_completion_rate | default(0) | round(1) }}%</li>
        <li>Cobertura média testes: {{ avg_metrics.avg_test_coverage | default(0) | round(1) }}%</li>
        <li>Qualidade média código: {{ avg_metrics.avg_code_quality | default(0) | round(1) }}/10</li>
      </ul>
    </section>
    <section>
      <h2>Top Projetos (máx. 20)</h2>
      <table>
        <thead>
          <tr><th>Projeto</th><th>Retrabalho</th><th>Conclusão</th></tr>
        </thead>
        <tbody>
          {% for metric in all_metrics[:20] %}
          <tr>
            <td>{{ metric.project_name }}</td>
            <td>{{ metric.rework_rate | round(1) }}%</td>
            <td>{{ metric.task_completion_rate | round(1) }}%</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </section>
  </body>
</html>
