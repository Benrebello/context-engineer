    C -->|"ce generate-tasks"| D["Task Authoring\nTASK.FR-xxx.md/.json"]
    D -->|"Wave Executor"| E["Implementation and Tests\nDevelopers + IDE AI"]
    E -->|"ce commit task"| F["Validation and Governance\nce validate + ce verify + Git Hooks"]
    F -->|"Metrics Snapshot"| G["Metrics and Dashboards\nce report + ce status + ce health"]

    %% Core Engine
    subgraph CoreEngine["Core Engine - core/engine.py"]
        ENG["ContextEngine\nOrchestrator"]
        TPL["TemplateEngine\nJinja2 Templates"]
        PAT["PatternLibrary\nReusable Patterns"]
        STK["StackPluginManager\nYAML Stack Plugins"]
        VAL["PRPValidator\nCross-Validation"]
        EST["EffortEstimator\nStory Points"]
        ENG --> TPL
        ENG --> PAT
        ENG --> STK
        ENG --> VAL
        ENG --> EST
    end

    B --> ENG
    C --> ENG
    D --> ENG
    F --> VAL

    %% Intelligence Layer
    subgraph IntelLayer["Intelligence Layer - core/cache.py"]
        CACHE["IntelligenceCache\nSQLite + Embeddings"]
        EMB["Embedding Cache\nBinary np.float32"]
        TOK["Token Usage Tracker\nrecord_token_usage"]
        SEM["Semantic Search\nai mode"]
        LEV["Levenshtein Search\nno-ai mode"]
        CACHE --> EMB
        CACHE --> TOK
        CACHE --> SEM
        CACHE --> LEV
    end

    ENG --> CACHE
    PAT --> CACHE

    %% AI Governance
    subgraph AIGov["AI Governance - Soft-Gate"]
        GOV["AIGovernanceService\nPreference Resolution"]
        LLM["LLMProvider\n8 Providers + CredentialVault"]
        HOOKS["GitHookManager\npre-push Soft/Hard Gate"]
        GOV --> LLM
        GOV --> HOOKS
    end

    ENG --> GOV
    F --> HOOKS

    %% Metrics and ROI
    subgraph MetricsROI["Metrics and ROI - core/metrics.py"]
        MET["MetricsCollector\nProjectMetrics JSON"]
        ROI["ROI Tracking\ntokens_saved / cost_usd"]
        RWK["Category Rework Rates\nConfidence Adjustment Feed"]
