{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PRP Phase Schema",
  "type": "object",
  "required": ["phase", "objectives"],
  "properties": {
    "phase": {
      "type": "string",
      "pattern": "^F[0-9]+$",
      "description": "Phase identifier (F0, F1, etc.)"
    },
    "objectives": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 1,
      "description": "List of objectives for this phase"
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "source"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["prd", "prp", "task", "external"]
          },
          "source": {"type": "string"},
          "required": {"type": "boolean", "default": true}
        }
      },
      "description": "Required inputs for this phase"
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "path"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["markdown", "json", "code", "config"]
          },
          "path": {"type": "string"},
          "schema": {"type": "string"}
        }
      },
      "description": "Expected outputs from this phase"
    },
    "validation": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["tool", "command", "expected"],
        "properties": {
          "tool": {
            "type": "string",
            "enum": ["tests", "lint", "format", "schema", "custom"]
          },
          "command": {"type": "string"},
          "expected": {"type": "string"}
        }
      },
      "description": "Validation commands for this phase"
    },
    "dependencies": {
      "type": "array",
      "items": {"type": "string"},
      "description": "List of phase IDs this phase depends on"
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "risk": {"type": "string"},
          "probability": {"type": "string", "enum": ["HIGH", "MEDIUM", "LOW"]},
          "impact": {"type": "string", "enum": ["HIGH", "MEDIUM", "LOW"]},
          "mitigation": {"type": "string"}
        }
      }
    }
  }
}

