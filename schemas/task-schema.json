{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Task Schema",
  "type": "object",
  "required": ["task_id", "objective"],
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^FR-[0-9]+$",
      "description": "Task identifier (FR-001, etc.)"
    },
    "objective": {
      "type": "string",
      "description": "Objective of the task"
    },
    "user_story": {
      "type": "object",
      "properties": {
        "id": {"type": "string"},
        "title": {"type": "string"},
        "as_a": {"type": "string"},
        "i_want": {"type": "string"},
        "so_that": {"type": "string"},
        "acceptance_criteria": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "inputs": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Required input files or references"
    },
    "steps": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Implementation steps"
    },
    "validation": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["tool", "command", "expected"],
        "properties": {
          "tool": {"type": "string"},
          "command": {"type": "string"},
          "expected": {"type": "string"}
        }
      }
    },
    "gherkin_scenarios": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "scenario": {"type": "string"},
          "given": {"type": "string"},
          "when": {"type": "string"},
          "then": {"type": "string"}
        }
      }
    }
  }
}

